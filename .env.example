# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=sa
DB_PASSWORD=sa
DB_NAME=wph_training_db

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# CORS Configuration
CORS_ORIGIN=*

# MOPH Provider-ID OAuth Configuration
MOPH_CLIENT_ID=
MOPH_CLIENT_SECRET=
PROVIDER_ID_CLIENT_ID=
PROVIDER_ID_CLIENT_SECRET=
PROVIDER_ID_REDIRECT_URI=http://localhost:3000/api/provider-auth/callback
PROVIDER_ID_OAUTH_URL=https://moph.id.th/oauth/redirect
PROVIDER_ID_TOKEN_URL=https://provider.id.th/api/v1/token
PROVIDER_ID_USER_INFO_URL=https://provider.id.th/api/v1/service/profile
 
